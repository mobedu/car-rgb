104:              static void ws2812_send_color(RGB_t color) {
105:                  ws2812_send_byte(color.r);
  0086    0871    LD	A,0x71
  0087    25B3    CALL	0x5B3
106:                  ws2812_send_byte(color.g);
  0088    0872    LD	A,0x72
  0089    25B3    CALL	0x5B3
107:                  ws2812_send_byte(color.b);
  008A    0873    LD	A,0x73
  008B    2DB3    JP	0x5B3
108:              }
