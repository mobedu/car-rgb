  0340    0858    LD	A,0x58
  0341    0758    ADDA	0x58
  0342    0758    ADDA	0x58
  0343    3EA2    ADDIA	0xA2
  0344    0084    LD	0x4,A
  0345    3018    LDIA	0x18
  0346    0180    CLR	0x0
  0347    0AD8    INCR	0x58
  0348    0258    SUBA	0x58
  0349    1C03    SNZB	0x3,0
  034A    2B33    JP	0x333
186:                                  }
