22:               void delay_ms(unsigned int ms) {
23:                   unsigned int i, j;
24:                   for (i = 0; i < ms; i++) {
  00F2    01F2    CLR	0x72
  00F3    01F3    CLR	0x73
  00F4    0871    LD	A,0x71
  00F5    0273    SUBA	0x73
  00F6    1D03    SNZB	0x3,2
  00F7    28FA    JP	0xFA
  00F8    0870    LD	A,0x70
  00F9    0272    SUBA	0x72
  00FA    1803    SZB	0x3,0
  00FB    0008    RET
25:                       for (j = 0; j < 1333; j++) {   // 16MHz 2T mode ~1ms
  00FC    01F4    CLR	0x74
  00FD    01F5    CLR	0x75
  00FE    0000    NOP
  00FF    0AF4    INCR	0x74
  0100    1903    SZB	0x3,2
  0101    0AF5    INCR	0x75
  0102    3005    LDIA	0x5
  0103    0275    SUBA	0x75
  0104    3035    LDIA	0x35
  0105    1903    SZB	0x3,2
  0106    0274    SUBA	0x74
  0107    1C03    SNZB	0x3,0
  0108    28FE    JP	0xFE
  0109    0AF2    INCR	0x72
  010A    1903    SZB	0x3,2
  010B    0AF3    INCR	0x73
  010C    28F4    JP	0xF4
26:                           asm("nop");
27:                       }
28:                   }
29:               }
