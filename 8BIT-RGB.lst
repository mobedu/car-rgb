181:                                  unsigned char i;
182:                                  for (i = 0; i < LED_COUNT; i++) {
  0332    01D8    CLR	0x58
183:                                      leds[i].r = 0;
  0333    0858    LD	A,0x58
  0334    0758    ADDA	0x58
  0335    0758    ADDA	0x58
  0336    3EA0    ADDIA	0xA0
  0337    0084    LD	0x4,A
  0338    1383    CLRB	0x3,7
  0339    0180    CLR	0x0
184:                                      leds[i].g = 0;
  033A    0858    LD	A,0x58
  033B    0758    ADDA	0x58
  033C    0758    ADDA	0x58
  033D    3EA1    ADDIA	0xA1
  033E    0084    LD	0x4,A
  033F    0180    CLR	0x0
