115:              void ws2812_update_RGB(RGB_t *leds, unsigned char num) {
  0252    00D5    LD	0x55,A
116:                  unsigned char i;
117:                  unsigned char key_was_pressed = 0;
  0253    01D4    CLR	0x54
118:              
119:                  // ЗЂЫЭЧАМьВщАДМќзДЬЌ
120:                  if (RA0 == 0) {
  0254    1683    SETB	0x3,5
  0255    1806    SZB	0x6,0
  0256    2A5A    JP	0x25A
121:                      key_was_pressed = 1;
  0257    1283    CLRB	0x3,5
  0258    01D4    CLR	0x54
  0259    0AD4    INCR	0x54
122:                  }
123:              
124:                  GIE = 0;
  025A    138B    CLRB	0xB,7
125:                  for (i = 0; i < num; i++) {
  025B    1283    CLRB	0x3,5
  025C    01D6    CLR	0x56
  025D    0851    LD	A,0x51
  025E    0256    SUBA	0x56
  025F    1803    SZB	0x3,0
  0260    2A74    JP	0x274
126:                      ws2812_send_color(leds[i]);
  0261    0856    LD	A,0x56
  0262    0756    ADDA	0x56
  0263    0756    ADDA	0x56
  0264    0755    ADDA	0x55
  0265    00D2    LD	0x52,A
  0266    0084    LD	0x4,A
  0267    1383    CLRB	0x3,7
  0268    0800    LD	A,0x0
  0269    00F1    LD	0x71,A
  026A    0A84    INCR	0x4
  026B    0800    LD	A,0x0
  026C    00F2    LD	0x72,A
  026D    0A84    INCR	0x4
  026E    0800    LD	A,0x0
  026F    00F3    LD	0x73,A
  0270    2086    CALL	0x86
  0271    1283    CLRB	0x3,5
  0272    0AD6    INCR	0x56
  0273    2A5D    JP	0x25D
127:                  }
128:                  ws2812_reset();
  0274    2081    CALL	0x81
129:                  GIE = 1;
  0275    178B    SETB	0xB,7
130:              
131:                  // ЗЂЫЭКѓШчЙћжЎЧАМьВтЕНАДМќЃЌЧвАДМќвбЪЭЗХЃЌСЂМДДІРэ
132:                  if (key_was_pressed && RA0 == 1) {
  0276    1283    CLRB	0x3,5
  0277    0854    LD	A,0x54
  0278    1903    SZB	0x3,2
  0279    0008    RET
  027A    1683    SETB	0x3,5
  027B    1C06    SNZB	0x6,0
  027C    0008    RET
133:                      EffectMode_t next_mode = (current_effect + 1) % EFFECT_COUNT;
  027D    1283    CLRB	0x3,5
  027E    2283    CALL	0x283
  027F    228D    CALL	0x28D
  0280    0870    LD	A,0x70
  0281    00D3    LD	0x53,A
134:                      effect_execute(next_mode);
  0282    28A2    JP	0xA2
135:                  }
136:              }
