8:                // ========== System Clock Initialization ==========
9:                void system_clock_init(void) {
10:                   // ЩшжУЯЕЭГЪБжгЮЊ 16MHz
11:                   // IRCF<2:0>=111 (16MHz), SWDTEN=0
12:                   OSCCON = 0x70;
  00AB    3070    LDIA	0x70
  00AC    0094    LD	0x14,A
13:               
14:                   // бгЪБШЗБЃЪБжгЮШЖЈ
15:                   unsigned char i;
16:                   for (i = 0; i < 20; i++) {
  00AD    01F0    CLR	0x70
  00AE    0000    NOP
  00AF    3014    LDIA	0x14
  00B0    0AF0    INCR	0x70
  00B1    0270    SUBA	0x70
  00B2    1803    SZB	0x3,0
  00B3    0008    RET
  00B4    28AE    JP	0xAE
17:                       asm("nop");
18:                   }
19:               }
20:               
