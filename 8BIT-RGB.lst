  034B    3018    LDIA	0x18
  034C    00D1    LD	0x51,A
  034D    30A0    LDIA	0xA0
  034E    2252    CALL	0x252
  034F    1683    SETB	0x3,5
  0350    1C06    SNZB	0x6,0
  0351    2B4F    JP	0x34F
188:                              }
