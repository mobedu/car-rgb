110:              static void ws2812_reset(void) {
111:                  RB1 = 0;
  0081    1086    CLRB	0x6,1
112:                  delay_ms(1);   // >50us
  0082    01F0    CLR	0x70
  0083    0AF0    INCR	0x70
  0084    01F1    CLR	0x71
  0085    28F2    JP	0xF2
113:              }
