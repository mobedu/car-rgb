138:              // ========== GPIO Initialization ==========
139:              static void ws2812_gpio_init(void) {
140:                  // ХфжУ RA0 ЮЊЪфШыЃЈАДМќЃЉ
141:                  TRISA |= (1 << 0);    // RA0 ЩшЮЊЪфШы
  0093    1405    SETB	0x5,0
142:              
143:                  // ANSEL0 ЧхСу bit0ЃЈНћгУ RA0 ФЃФтЙІФмЃЉ
144:                  ANSEL0 &= ~(1 << 0);
  0094    1013    CLRB	0x13,0
145:              
146:                  // ANSEL1 (94H): Bit1 = ANS9 = RB1, set to 0 for digital I/O
147:                  ANSEL1 &= ~(1 << 1);
  0095    1094    CLRB	0x14,1
148:              
149:                  // TRISB (05H): Bit1 = TRISB1, set to 0 for output
150:                  TRISB &= ~(1 << 1);
  0096    1283    CLRB	0x3,5
  0097    1085    CLRB	0x5,1
151:              
152:                  // RB1 = 0 initial low
153:                  RB1 = 0;
  0098    1086    CLRB	0x6,1
  0099    0008    RET
154:              }
