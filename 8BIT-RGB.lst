  0323    0ABB    INCR	0x3B
174:                          }
175:                          // ГЄАДМьВтЃКдМ1.5УыЃЈ150ДЮ10msб­ЛЗЃЉ
176:                          if (key_press_counter == 150) {
  0324    3096    LDIA	0x96
  0325    063B    XORA	0x3B
  0326    1D03    SNZB	0x3,2
  0327    0008    RET
177:                              // ГЄАДЃКЧаЛЛПЊЙи
