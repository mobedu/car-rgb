#include <sc.h>

// в§НХЖЈвх
#define WS2812_PIN RB1
#define WS2812_TRIS TRISB1

// беЩЋНсЙЙЬхЃЈGRBЫГађЃЉ
typedef struct {
    unsigned char g;
    unsigned char r;
    unsigned char b;
} RGB_Color;

// дЄЖЈвхГЃгУбеЩЋ
RGB_Color COLOR_RED = {0, 255, 0};
RGB_Color COLOR_GREEN = {255, 0, 0};
RGB_Color COLOR_BLUE = {0, 0, 255};
RGB_Color COLOR_WHITE = {255, 255, 255};
RGB_Color COLOR_YELLOW = {255, 255, 0};
RGB_Color COLOR_CYAN = {255, 0, 255};
RGB_Color COLOR_MAGENTA = {0, 255, 255};
RGB_Color COLOR_OFF = {0, 0, 0};

// LEDЪ§СП
#define LED_COUNT 16

// LEDЪ§ОнЛКГхЧј
RGB_Color led_buffer[LED_COUNT];

// КЏЪ§ЩљУї
void delay_ns(unsigned int cycles);
void send_bit(unsigned char bit_val);
void send_byte(unsigned char data);
void send_pixel(RGB_Color color);
void ws2812_send_all(void);
void set_led_color(unsigned char index, RGB_Color color);
void set_all_leds(RGB_Color color);
RGB_Color color_gradient(unsigned char position, unsigned char max_pos);
RGB_Color color_brightness(RGB_Color color, unsigned char brightness);
void ws2812_init(void);

// ШэМўбгЪБКЏЪ§
void delay_ns(unsigned int cycles) {
    while(cycles--) {
        asm("nop");
    }
}

// ЗЂЫЭвЛИіЮЛ
void send_bit(unsigned char bit_val) {
    if (bit_val) {
        // ЗЂЫЭ1ТыЃКИп700nsЃЌЕЭ800ns
        WS2812_PIN = 1;
        delay_ns(28);  // 700ns @ 16MHz/4T
        WS2812_PIN = 0;
        delay_ns(32);  // 800ns @ 16MHz/4T
    } else {
        // ЗЂЫЭ0ТыЃКИп350nsЃЌЕЭ800ns
        WS2812_PIN = 1;
        delay_ns(14);  // 350ns @ 16MHz/4T
        WS2812_PIN = 0;
        delay_ns(32);  // 800ns @ 16MHz/4T
    }
}

// ЗЂЫЭвЛИізжНк
void send_byte(unsigned char data) {
    unsigned char i;
    for(i = 0; i < 8; i++) {
        send_bit((data & 0x80) ? 1 : 0);
        data <<= 1;
    }
}

// ЗЂЫЭвЛИіЯёЫиЃЈGRBЫГађЃЉ
void send_pixel(RGB_Color color) {
    send_byte(color.g);  // G
    send_byte(color.r);  // R
    send_byte(color.b);  // B
}

// ЗЂЫЭЫљгаLEDЪ§Он
void ws2812_send_all(void) {
    unsigned char i;
    
    // ЗЂЫЭЫљгаLEDЪ§Он
    for(i = 0; i < LED_COUNT; i++) {
        send_pixel(led_buffer[i]);
    }
    
    // ИДЮЛаХКХЃЈжСЩй50ІЬsЕЭЕчЦНЃЉ
    WS2812_PIN = 0;
    delay_ns(2000);  // 50ІЬs @ 16MHz/4T
}

// ЩшжУЕЅИіLEDбеЩЋ
void set_led_color(unsigned char index, RGB_Color color) {
    if (index < LED_COUNT) {
        led_buffer[index] = color;
    }
}

// ЩшжУЫљгаLEDбеЩЋ
void set_all_leds(RGB_Color color) {
    unsigned char i;
    for(i = 0; i < LED_COUNT; i++) {
        led_buffer[i] = color;
    }
}

// НЅБфбеЩЋКЏЪ§
RGB_Color color_gradient(unsigned char position, unsigned char max_pos) {
    RGB_Color color;
    unsigned int temp;
    
    // МђЕЅЕФВЪКчНЅБф
    if (position < max_pos/3) {
        // Кь->ЛЦ
        color.r = 255;
        temp = (unsigned int)position * 255 / (max_pos/3);
        color.g = (unsigned char)temp;
        color.b = 0;
    } else if (position < 2*max_pos/3) {
        // ЛЦ->ТЬ
        temp = 255 - ((unsigned int)(position - max_pos/3) * 255 / (max_pos/3));
        color.r = (unsigned char)temp;
        color.g = 255;
        color.b = 0;
    } else {
        // ТЬ->РЖ
        color.r = 0;
        temp = 255 - ((unsigned int)(position - 2*max_pos/3) * 255 / (max_pos/3));
        color.g = (unsigned char)temp;
        temp = ((unsigned int)(position - 2*max_pos/3) * 255 / (max_pos/3));
        color.b = (unsigned char)temp;
    }
    
    return color;
}

// ССЖШЕїећКЏЪ§
RGB_Color color_brightness(RGB_Color color, unsigned char brightness) {
    RGB_Color result;
    unsigned int temp;
    
    // brightness: 0-255
    temp = (unsigned int)color.r * brightness / 255;
    result.r = (unsigned char)temp;
    
    temp = (unsigned int)color.g * brightness / 255;
    result.g = (unsigned char)temp;
    
    temp = (unsigned int)color.b * brightness / 255;
    result.b = (unsigned char)temp;
    
    return result;
}

// ГѕЪМЛЏКЏЪ§
void ws2812_init(void) {
    // ГѕЪМЛЏIO
    ANSEL1 &= ~(1 << 1);  // НћгУRB1ФЃФтЙІФм
    WS2812_TRIS = 0;      // RB1ЩшЮЊЪфГі
    WS2812_PIN = 0;       // ГѕЪМЕЭЕчЦН
    
    // ГѕЪМЛЏЫљгаLEDЮЊЙиБезДЬЌ
    set_all_leds(COLOR_OFF);
    ws2812_send_all();
}

// жїКЏЪ§
void main(void) {
    unsigned char i;
    unsigned char mode = 0;
    unsigned char brightness = 128;  // 50%ССЖШ
    static unsigned char breathe_dir = 0;  // КєЮќЕЦЗНЯђ
    
    // ГѕЪМЛЏWS2812B
    ws2812_init();
    
    while(1) {
        switch(mode) {
            case 0: // ФЃЪН0ЃКЫљгаLEDКьЩЋ
                set_all_leds(color_brightness(COLOR_RED, brightness));
                break;
                
            case 1: // ФЃЪН1ЃКЫљгаLEDТЬЩЋ
                set_all_leds(color_brightness(COLOR_GREEN, brightness));
                break;
                
            case 2: // ФЃЪН2ЃКЫљгаLEDРЖЩЋ
                set_all_leds(color_brightness(COLOR_BLUE, brightness));
                break;
                
            case 3: // ФЃЪН3ЃКЫљгаLEDАзЩЋ
                set_all_leds(color_brightness(COLOR_WHITE, brightness));
                break;
                
            case 4: // ФЃЪН4ЃКВЪКчНЅБф
                for(i = 0; i < LED_COUNT; i++) {
                    set_led_color(i, color_gradient(i, LED_COUNT));
                }
                break;
                
            case 5: // ФЃЪН5ЃКСїЫЎЕЦЃЈКьЩЋЃЉ
                for(i = 0; i < LED_COUNT; i++) {
                    set_all_leds(COLOR_OFF);
                    set_led_color(i, color_brightness(COLOR_RED, brightness));
                    ws2812_send_all();
                    delay_ns(20000);  // 5msбгГй
                }
                continue;  // ЬјЙ§ЯТУцЕФws2812_send_all()
                
            case 6: // ФЃЪН6ЃККєЮќЕЦаЇЙћ
                if (breathe_dir == 0) {
                    brightness++;
                    if (brightness >= 255) breathe_dir = 1;
                } else {
                    brightness--;
                    if (brightness <= 10) breathe_dir = 0;
                }
                set_all_leds(color_brightness(COLOR_CYAN, brightness));
                break;
        }
        
        // ЗЂЫЭЪ§ОнЕНLEDЃЈФЃЪН5Г§ЭтЃЉ
        if (mode != 5) {
            ws2812_send_all();
        }
        
        // бгГй
        delay_ns(400000);  // 100msбгГй
        
        // ЧаЛЛФЃЪН
        mode++;
        if (mode > 6) mode = 0;
    }
}
